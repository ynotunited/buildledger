APP_NAME=BuildLedger
APP_ENV=production
APP_KEY=base64:GENERATE_A_NEW_PRODUCTION_APP_KEY
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,auth,api,security,analytics,support
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_AUTH_LEVEL=info
LOG_API_LEVEL=warning
LOG_SECURITY_LEVEL=warning
LOG_ANALYTICS_LEVEL=info
LOG_SUPPORT_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=buildledger
DB_USERNAME=buildledger
DB_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD
DB_SSLMODE=require

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_COOKIE=buildledger_session
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD_OR_KEEP_NULL_IF_PRIVATE_AND_UNAUTHENTICATED
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.yourmailprovider.com
MAIL_PORT=587
MAIL_USERNAME=REPLACE_WITH_MAIL_USERNAME
MAIL_PASSWORD=REPLACE_WITH_MAIL_PASSWORD
MAIL_FROM_ADDRESS=hello@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FRONTEND_URL=https://app.yourdomain.com
SECURITY_INVITE_ONLY=true
SANCTUM_STATEFUL_DOMAINS=app.yourdomain.com,api.yourdomain.com
SANCTUM_EXPIRATION=120
AUTH_PASSWORD_RESET_EXPIRE=60
AUTH_EMAIL_VERIFICATION_EXPIRE=60
SECURITY_ENFORCE_HTTPS=true
SECURITY_TRUSTED_PROXIES=*
SECURITY_CONTRACT_SIGNING_LINK_TTL_HOURS=168
SECURITY_INVOICE_PAYMENT_LINK_TTL_HOURS=168
SECURITY_REDIS_REQUIRED_IN_PRODUCTION=true
SECURITY_ROW_LEVEL_SECURITY_REQUIRED=true
SECURITY_API_GATEWAY_ENFORCED=true
SECURITY_API_GATEWAY_REQUIRE_REQUEST_ID=true
SECURITY_API_GATEWAY_ALLOWED_HOSTS=app.yourdomain.com,api.yourdomain.com
API_GATEWAY_SHARED_SECRET=REPLACE_WITH_LONG_RANDOM_GATEWAY_SECRET
SECURITY_SUSPICIOUS_REQUESTS_PER_MINUTE=120
SECURITY_SUSPICIOUS_FAILURES_PER_MINUTE=25
SECURITY_WAF_BLOCK_DURATION_MINUTES=10
SECURITY_TELEMETRY_EVENT_LIMIT_PER_MINUTE=120
SECURITY_FRONTEND_ERROR_LIMIT_PER_MINUTE=30
SECURITY_PAID_API_REQUESTS_PER_MINUTE=8
SECURITY_PAID_API_REQUESTS_PER_HOUR=40
SECURITY_AI_PROMPT_USER_DELIMITER_START="BEGIN USER CONTENT"
SECURITY_AI_PROMPT_USER_DELIMITER_END="END USER CONTENT"
OPS_PAYMENTS_ENABLED=true
OPS_WEBHOOKS_ENABLED=true
OPS_BACKUPS_ENABLED=true
OPS_ALERTS_ENABLED=true
OPS_RECONCILIATION_ENABLED=true
OPS_BACKUP_DISK=local
OPS_BACKUP_PREFIX=backups
OPS_RECONCILIATION_WINDOW_HOURS=48
BILLING_TRIAL_DAYS=30
BILLING_RENEWAL_GRACE_HOURS=72

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

# Optional object storage
# FILESYSTEM_DISK=r2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=
# AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true
