APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com
APP_VERSION=1.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,auth,api,security
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_AUTH_LEVEL=info
LOG_API_LEVEL=warning
LOG_SECURITY_LEVEL=warning
LOG_ANALYTICS_LEVEL=info
LOG_SUPPORT_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=buildledger
DB_USERNAME=buildledger
DB_PASSWORD=
DB_SSLMODE=require
# Never expose database ports to the public internet. Bind DB to a private IP or localhost only.

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_COOKIE=buildledger_session
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@buildledger.local"
MAIL_FROM_NAME="BuildLedger"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FRONTEND_URL=https://app.example.com
SECURITY_INVITE_ONLY=true
SANCTUM_STATEFUL_DOMAINS=app.example.com,api.example.com
SANCTUM_EXPIRATION=120
AUTH_PASSWORD_RESET_EXPIRE=60
AUTH_EMAIL_VERIFICATION_EXPIRE=60
SECURITY_ENFORCE_HTTPS=true
SECURITY_TRUSTED_PROXIES=*
SECURITY_CONTRACT_SIGNING_LINK_TTL_HOURS=168
SECURITY_INVOICE_PAYMENT_LINK_TTL_HOURS=168
SECURITY_REDIS_REQUIRED_IN_PRODUCTION=true
SECURITY_ROW_LEVEL_SECURITY_REQUIRED=true
SECURITY_API_GATEWAY_ENFORCED=false
SECURITY_API_GATEWAY_REQUIRE_REQUEST_ID=true
SECURITY_API_GATEWAY_ALLOWED_HOSTS=
API_GATEWAY_SHARED_SECRET=
SECURITY_SUSPICIOUS_REQUESTS_PER_MINUTE=120
SECURITY_SUSPICIOUS_FAILURES_PER_MINUTE=25
SECURITY_WAF_BLOCK_DURATION_MINUTES=10
SECURITY_TELEMETRY_EVENT_LIMIT_PER_MINUTE=120
SECURITY_FRONTEND_ERROR_LIMIT_PER_MINUTE=30
SECURITY_PAID_API_REQUESTS_PER_MINUTE=8
SECURITY_PAID_API_REQUESTS_PER_HOUR=40
SECURITY_AI_PROMPT_USER_DELIMITER_START=BEGIN USER CONTENT
SECURITY_AI_PROMPT_USER_DELIMITER_END=END USER CONTENT
OPS_PAYMENTS_ENABLED=true
OPS_WEBHOOKS_ENABLED=true
OPS_BACKUPS_ENABLED=true
OPS_ALERTS_ENABLED=true
OPS_RECONCILIATION_ENABLED=true
OPS_BACKUP_DISK=local
OPS_BACKUP_PREFIX=backups
OPS_BACKUP_RETENTION_DAYS=30
OPS_RECONCILIATION_WINDOW_HOURS=48
BILLING_TRIAL_DAYS=30
BILLING_RENEWAL_GRACE_HOURS=72

# Paystack (https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Flutterwave (https://dashboard.flutterwave.com)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

# Cloudflare R2 (optional — uses AWS SDK)
# FILESYSTEM_DISK=r2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=
# AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true
